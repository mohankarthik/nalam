# The codebook is generated from the user's own spreadsheet and encodes which
# tests they track and the ranges they chose. Personal.
data/analytes.json

# The deny-list the pre-commit PII guard reads. It names real people, so
# committing it would be the exact thing it exists to prevent.
data/pii_denylist.txt

# Extracted health records.
data/health.db
data/health.db.*
data/state/

# Test fixtures built from real medical records: hand-typed values, raw
